{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "agent-os-spike-04",
  "main": "worker.ts",
  "compatibility_date": "2026-04-15",
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      { "name": "ADMISSION_DO", "class_name": "AdmissionDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["AdmissionDO"] }
  ],
  "observability": {
    "enabled": true
  }
}

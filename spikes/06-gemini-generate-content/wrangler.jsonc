{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "agent-os-spike-06-gemini-generate-content",
  "main": "worker.ts",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      { "name": "SPIKE_DO", "class_name": "SpikeAgentDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SpikeAgentDO"] }
  ],
  "observability": {
    "enabled": true
  }
}

{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "agent-os-spike-02",
  "main": "worker.ts",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT_DO",
        "class_name": "AgentDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AgentDO"]
    }
  ],
  "workflows": [
    {
      "binding": "INTERVIEW_WORKFLOW",
      "name": "agent-os-spike-02-interview",
      "class_name": "InterviewWorkflow"
    }
  ],
  "observability": {
    "enabled": true
  }
}

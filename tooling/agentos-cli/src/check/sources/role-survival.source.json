{
  "schemaVersion": 1,
  "roles": [
    {
      "id": "law-contract-owner",
      "meaning": "owns substrate laws, value vocabulary, facts, or protocol contracts"
    },
    {
      "id": "capability-protocol",
      "meaning": "owns a backend-neutral execution, runtime, or capability protocol"
    },
    {
      "id": "provider-bundle",
      "meaning": "materializes a protocol for a concrete backend, provider, or host"
    },
    {
      "id": "projection-sink",
      "meaning": "derives authored, wire, stream, client, or workspace host views from owned facts"
    },
    {
      "id": "repo-local-tooling",
      "meaning": "supports this repository's generation, checks, docs, release, or ops surfaces"
    }
  ],
  "packageRoleRules": [
    {
      "role": "law-contract-owner",
      "paths": [
        "packages/backends/protocol",
        "packages/kernel",
        "packages/llm-protocol",
        "packages/runtime-protocol",
        "packages/telemetry-protocol"
      ],
      "pathPrefixes": ["packages/carriers"],
      "reason": "these packages own durable vocabulary, carrier facts, or backend-neutral contract shapes"
    },
    {
      "role": "capability-protocol",
      "paths": [
        "packages/composers/attached-stream",
        "packages/composers/turn-stream",
        "packages/execution-domains/sandbox",
        "packages/execution-domains/workspace-env",
        "packages/runtime"
      ],
      "pathPrefixes": [],
      "reason": "these packages define runtime or execution protocols without binding a concrete provider"
    },
    {
      "role": "provider-bundle",
      "paths": [
        "packages/backends/cloudflare-do",
        "packages/backends/in-memory",
        "packages/backends/node-postgres",
        "packages/execution-domains/sandbox-cloudflare",
        "packages/execution-domains/workspace-env-cloudflare",
        "packages/execution-domains/workspace-env-local"
      ],
      "pathPrefixes": ["packages/providers"],
      "reason": "these packages provide concrete backend, host, or provider materializations"
    },
    {
      "role": "projection-sink",
      "paths": [
        "packages/composers/agent-authoring",
        "packages/composers/config",
        "packages/composers/run-stream",
        "packages/composers/workspace-agent",
        "packages/composers/workspace-binding",
        "tooling/ops-api"
      ],
      "pathPrefixes": ["packages/client", "packages/transports", "packages/wire-adapters"],
      "reason": "these packages derive authored, stream, wire, client, or workspace host views without owning runtime truth"
    },
    {
      "role": "repo-local-tooling",
      "paths": [],
      "pathPrefixes": ["tooling"],
      "excludePaths": ["tooling/ops-api"],
      "reason": "tooling packages are repo-local generation, check, docs, release, or ops surfaces"
    }
  ],
  "exportSurfaces": {
    "packagePublicApi": "inherit-package-role",
    "source": "PUBLIC_API.md and docs/surface.json apiSource"
  },
  "scriptSurfaces": {
    "rootScripts": {
      "role": "repo-local-tooling",
      "sourceRule": "repo-tooling-surface"
    },
    "packageScripts": {
      "role": "repo-local-tooling",
      "allowedNames": ["build", "check", "dev", "test", "test:runtime", "test:unit", "typecheck"]
    }
  },
  "docSurfaces": {
    "surfaceSource": {
      "path": "docs/surface.json",
      "role": "repo-local-tooling"
    },
    "packageDocs": "inherit-package-role",
    "packageApiDocs": "inherit-package-role",
    "agentSources": [
      {
        "path": "docs/agent/boundary-rules.source.json",
        "pointer": "rules",
        "role": "law-contract-owner"
      },
      {
        "path": "docs/agent/capability-rules.source.json",
        "pointer": "rules",
        "role": "capability-protocol"
      },
      {
        "path": "docs/agent/error-metadata.source.json",
        "pointer": "errors",
        "role": "law-contract-owner"
      },
      {
        "path": "docs/agent/external-vocabulary.source.json",
        "pointer": "vocabulary",
        "role": "projection-sink"
      },
      {
        "path": "docs/agent/gates.source.json",
        "pointer": "packageOverrides",
        "role": "repo-local-tooling"
      },
      {
        "path": "docs/agent/invariants.source.json",
        "pointer": "invariants",
        "role": "law-contract-owner"
      },
      {
        "path": "docs/agent/primitive-evidence.source.json",
        "pointer": "evidence",
        "role": "law-contract-owner"
      },
      {
        "path": "docs/agent/recipes.source.json",
        "pointer": "recipes",
        "role": "repo-local-tooling"
      }
    ]
  }
}

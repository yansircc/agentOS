{
  "name": "agent-os-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/runtime",
    "packages/client/*",
    "packages/carriers/*",
    "packages/execution-domains/*",
    "packages/providers/*",
    "packages/composers/*",
    "packages/transports/*",
    "packages/wire-adapters/*",
    "tooling/*"
  ],
  "type": "module",
  "scripts": {
    "agentos": "node tooling/agentos-cli/src/main.mjs",
    "typecheck": "sh -c 'tsc -b --noEmit --force; code=$?; tsc -b --clean; exit $code'",
    "test": "vp run --cache -r test",
    "docs:generate": "bun run agentos -- generate docs",
    "docs:check": "bun run agentos -- check docs",
    "effect-manifests:generate": "bun run agentos -- generate effect-manifests",
    "effect-manifests:check": "bun run agentos -- check effect-manifests",
    "check": "bun run agentos -- check default",
    "check:runtime": "vp run --cache -r test:runtime",
    "check:release": "bun run check:structural && bun run typecheck && bun run test && bun run check:distribution && bun run test:internal-consumer && rm -rf /tmp/agentos-release-scan && mkdir -p /tmp/agentos-release-scan && effect-skill-scan . --strict --output gate-json --evidence /tmp/agentos-release-scan",
    "check:full": "bun run check:release && bun run docs:site:check && bun run check:runtime",
    "docs:project": "bun run agentos -- generate site",
    "docs:project:watch": "bun run agentos -- generate site --watch",
    "docs:site:dev": "sh -c 'bun run agentos -- generate site --watch & watcher=$!; trap \"kill $watcher\" INT TERM EXIT; bun run --cwd tooling/docs-site dev'",
    "docs:site:build": "bun run agentos -- generate site && bun run --cwd tooling/docs-site build && bun run agentos -- check site",
    "docs:site:check": "bun run docs:check && bun run docs:site:build",
    "build:internal-packages": "node tooling/distribution/distribution.mjs build",
    "pack:internal": "node tooling/distribution/distribution.mjs pack",
    "check:distribution": "node tooling/distribution/distribution.mjs check",
    "test:internal-consumer": "node tooling/distribution/distribution.mjs test-consumer",
    "publish:internal": "node tooling/distribution/distribution.mjs publish",
    "registry:local": "node tooling/distribution/distribution.mjs local-registry",
    "publish:local": "node tooling/distribution/distribution.mjs publish-local",
    "install:consumer": "node tooling/distribution/distribution.mjs install-consumer",
    "restore:consumer": "node tooling/distribution/distribution.mjs restore-consumer",
    "check:structural": "bun run agentos -- check structural"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@effect/ai-anthropic": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/sql-sqlite-do": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/react": "catalog:",
    "effect": "catalog:",
    "fast-check": "catalog:",
    "react": "catalog:",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.14",
  "agentOsRelease": {
    "version": "0.5.16",
    "npmScope": "@yansirplus",
    "npmAccess": "public"
  },
  "agentos": {
    "backendNeutralityStatus": "backend-neutral",
    "backendNeutrality": {
      "productionRuntimeProfiles": [
        {
          "id": "cloudflare-worker",
          "sourcePackageName": "@agent-os/runtime",
          "subpath": "@agent-os/runtime/cloudflare",
          "contractTest": "packages/runtime/test/cloudflare/backend-protocol-contract.test.ts"
        },
        {
          "id": "node",
          "sourcePackageName": "@agent-os/runtime",
          "subpath": "@agent-os/runtime/node",
          "contractTest": "packages/runtime/test/node/backend-protocol-contract.runtime.test.ts"
        }
      ]
    },
    "boundaryGuard": {
      "matrixVersion": "2026-06-09.1",
      "activeStages": [
        "boundary-prepared",
        "backend-neutral"
      ]
    }
  },
  "catalog": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20251201.0",
    "@effect/ai-anthropic": "^4.0.0-beta.84",
    "@effect/language-service": "^0.86.2",
    "@effect/sql-sqlite-do": "^4.0.0-beta.84",
    "@effect/vitest": "^4.0.0-beta.84",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.16",
    "effect": "^4.0.0-beta.84",
    "fast-check": "^4.8.0",
    "react": "^19.2.7",
    "svelte": "^5.56.2",
    "typescript": "^5.7.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.22",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.22",
    "vite-plus": "0.1.22"
  }
}

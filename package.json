{
  "name": "agent-os-monorepo",
  "private": true,
  "workspaces": [
    "packages/kernel",
    "packages/runtime",
    "packages/runtime-protocol",
    "packages/telemetry-protocol",
    "packages/llm-protocol",
    "packages/backends/*",
    "packages/carriers/*",
    "packages/execution-domains/*",
    "packages/providers/*",
    "packages/composers/*",
    "packages/transports/*",
    "tooling/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "sh -c 'tsc -b --noEmit --force; code=$?; tsc -b --clean; exit $code'",
    "test": "vp run --cache -r test",
    "docs:generate": "node scripts/generate-docs.mjs && node scripts/generate-agent-docs.mjs && bun scripts/generate-carrier-reference.mjs && node scripts/project-docs-site.mjs",
    "docs:check": "node scripts/generate-docs.mjs --check && node scripts/generate-agent-docs.mjs --check && bun scripts/generate-carrier-reference.mjs --check && node scripts/check-doc-structure.mjs && node scripts/project-docs-site.mjs --check",
    "effect-manifests:generate": "node scripts/generate-effect-skill-manifests.mjs",
    "effect-manifests:check": "node scripts/generate-effect-skill-manifests.mjs --check",
    "check:public-api": "node scripts/check-public-api.mjs --self-test && node scripts/check-public-api.mjs",
    "check:event-namespaces": "node scripts/check-event-namespaces.mjs --self-test && node scripts/check-event-namespaces.mjs",
    "check:transaction-sync": "node scripts/check-transaction-sync-sync-only.mjs --self-test && node scripts/check-transaction-sync-sync-only.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:backend-neutrality": "node scripts/check-backend-neutrality.mjs",
    "check:source-aliases": "bun scripts/check-source-aliases.mjs",
    "check:spikes": "node scripts/check-spike-hygiene.mjs",
    "test:tool-mutation-boundary": "node scripts/check-tool-mutation-boundary.mjs --self-test && node scripts/check-tool-mutation-boundary.mjs",
    "test:agent-manifest-intent-boundary": "node scripts/check-agent-manifest-intent-boundary.mjs --self-test && node scripts/check-agent-manifest-intent-boundary.mjs",
    "test:intent-settlement-boundary": "node scripts/check-intent-settlement-boundary.mjs --self-test && node scripts/check-intent-settlement-boundary.mjs",
    "test:facade-run-scoped-bindings": "node scripts/check-facade-run-scoped-bindings.mjs --self-test && node scripts/check-facade-run-scoped-bindings.mjs",
    "test:replay-dispatch-snapshot": "node scripts/check-replay-dispatch-snapshot.mjs --self-test && node scripts/check-replay-dispatch-snapshot.mjs",
    "check": "vp check && bun run docs:check && bun run effect-manifests:check && bun run check:public-api && bun run check:event-namespaces && bun run check:transaction-sync && bun run check:boundaries -- --self-test && bun run check:boundaries && bun run check:backend-neutrality -- --self-test && bun run check:backend-neutrality && bun run check:source-aliases && bun run check:spikes && bun run check:distribution && bun run typecheck && bun run test",
    "check:runtime": "vp run --cache -r test:runtime",
    "check:full": "bun run check && bun run docs:site:check && bun run check:runtime",
    "docs:project": "node scripts/project-docs-site.mjs",
    "docs:project:watch": "node scripts/project-docs-site.mjs --watch",
    "docs:site:dev": "sh -c 'node scripts/project-docs-site.mjs --watch & watcher=$!; trap \"kill $watcher\" INT TERM EXIT; bun run --cwd tooling/docs-site dev'",
    "docs:site:build": "bun run docs:project && bun run --cwd tooling/docs-site build && node scripts/check-docs-site-build.mjs",
    "docs:site:check": "bun run docs:check && bun run docs:site:build",
    "build:internal-packages": "node tooling/distribution/distribution.mjs build",
    "pack:internal": "node tooling/distribution/distribution.mjs pack",
    "check:distribution": "node tooling/distribution/distribution.mjs check",
    "test:internal-consumer": "node tooling/distribution/distribution.mjs test-consumer",
    "publish:internal": "node tooling/distribution/distribution.mjs publish",
    "registry:local": "node tooling/distribution/distribution.mjs local-registry",
    "publish:local": "node tooling/distribution/distribution.mjs publish-local"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@effect/ai": "catalog:",
    "@effect/ai-anthropic": "catalog:",
    "@effect/ai-google": "catalog:",
    "@effect/ai-openai": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/sql": "catalog:",
    "@effect/sql-sqlite-do": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/react": "catalog:",
    "effect": "catalog:",
    "fast-check": "catalog:",
    "react": "catalog:",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.14",
  "agentOsRelease": {
    "version": "0.2.9"
  },
  "agentos": {
    "backendNeutralityStatus": "boundary-prepared",
    "backendNeutrality": {
      "productionBackendPackages": []
    },
    "boundaryGuard": {
      "matrixVersion": "2026-06-09.1",
      "activeStages": [
        "boundary-prepared"
      ]
    }
  },
  "catalog": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20251201.0",
    "@effect/ai": "^0.35.0",
    "@effect/ai-anthropic": "^0.25.0",
    "@effect/ai-google": "^0.14.0",
    "@effect/ai-openai": "^0.39.2",
    "@effect/experimental": "^0.60.0",
    "@effect/language-service": "^0.86.2",
    "@effect/platform": "^0.96.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-sqlite-do": "^0.29.0",
    "@effect/vitest": "^0.29.0",
    "@types/react": "^19.2.16",
    "effect": "^3.21.0",
    "fast-check": "^4.8.0",
    "react": "^19.2.7",
    "svelte": "^5.56.2",
    "typescript": "^5.7.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.22",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.22",
    "vite-plus": "0.1.22"
  }
}

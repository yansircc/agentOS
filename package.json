{
  "name": "agent-os-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "agentos": "node packages/cli/src/main.mjs",
    "typecheck": "sh -c 'tsc -b --noEmit --force; code=$?; tsc -b --clean; exit $code'",
    "test": "vp run --cache -r test",
    "docs:generate": "pnpm run agentos generate docs",
    "docs:check": "pnpm run agentos check docs",
    "effect-manifests:generate": "pnpm run agentos generate effect-manifests",
    "effect-manifests:check": "pnpm run agentos check effect-manifests",
    "check": "pnpm run agentos check default",
    "check:runtime": "vp run --cache -r test:runtime",
    "check:release": "pnpm run check:structural && pnpm run typecheck && pnpm run test && pnpm run check:distribution && pnpm run test:internal-consumer && pnpm run agentos check effect-scan --evidence /tmp/agentos-release-scan",
    "check:full": "pnpm run check:release && pnpm run docs:site:check && pnpm run check:runtime",
    "docs:project": "pnpm run agentos generate site",
    "docs:project:watch": "pnpm run agentos generate site --watch",
    "docs:site:dev": "sh -c 'pnpm run agentos generate site --watch & watcher=$!; trap \"kill $watcher\" INT TERM EXIT; pnpm --filter @agent-os/docs-site dev'",
    "docs:site:build": "pnpm run agentos generate site && pnpm --filter @agent-os/docs-site build && pnpm run agentos check site",
    "docs:site:check": "pnpm run docs:check && pnpm run docs:site:build",
    "agent-catalog:generate": "node packages/cli/src/generate/generate-agent-catalog.mjs",
    "agent-catalog:check": "node packages/cli/src/generate/generate-agent-catalog.mjs --check",
    "build:internal-packages": "node tooling/distribution/distribution.mjs build",
    "pack:internal": "node tooling/distribution/distribution.mjs pack",
    "check:distribution": "node tooling/distribution/distribution.mjs check",
    "test:internal-consumer": "node tooling/distribution/distribution.mjs test-consumer",
    "publish:internal": "node tooling/distribution/distribution.mjs publish",
    "registry:local": "node tooling/distribution/distribution.mjs local-registry",
    "publish:local": "node tooling/distribution/distribution.mjs publish-local",
    "install:consumer": "node packages/cli/src/main.mjs consumer install",
    "status:consumer": "node packages/cli/src/main.mjs consumer status",
    "restore:consumer": "node packages/cli/src/main.mjs consumer restore",
    "check:structural": "pnpm run agentos check structural"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@effect/ai-anthropic": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/sql-sqlite-do": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "effect": "catalog:",
    "esbuild": "catalog:",
    "fast-check": "catalog:",
    "react": "catalog:",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "packageManager": "pnpm@11.9.0",
  "agentOsRelease": {
    "version": "0.5.17",
    "npmScope": "@yansirplus",
    "npmAccess": "public"
  },
  "agentos": {
    "backendNeutralityStatus": "backend-neutral",
    "backendNeutrality": {
      "productionRuntimeProfiles": [
        {
          "id": "cloudflare-worker",
          "sourcePackageName": "@agent-os/runtime",
          "subpath": "@agent-os/runtime/cloudflare",
          "contractTest": "packages/runtime/test/cloudflare/backend-protocol-contract.test.ts"
        },
        {
          "id": "node",
          "sourcePackageName": "@agent-os/runtime",
          "subpath": "@agent-os/runtime/node",
          "contractTest": "packages/runtime/test/node/backend-protocol-contract.runtime.test.ts"
        }
      ]
    },
    "boundaryGuard": {
      "matrixVersion": "2026-06-09.1",
      "activeStages": [
        "boundary-prepared",
        "backend-neutral"
      ]
    }
  }
}

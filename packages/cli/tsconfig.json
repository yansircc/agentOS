{
  "compilerOptions": {
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/packages-cli.tsbuildinfo",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "../../tooling/types/vite-plus-test-config/index.d.ts"],
  "extends": "../../tsconfig.source-paths.json"
}

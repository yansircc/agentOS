{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@agent-os/deploy": ["../../carriers/deploy/src/index.ts"],
      "@agent-os/kernel/effect-claim": ["../../kernel/src/effect-claim.ts"]
    },
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "vitest.config.ts",
    "../../../types/vite-plus-test-config/index.d.ts"
  ]
}

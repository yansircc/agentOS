{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "agent-os-core-test",
  "main": "./test/test-worker.ts",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT_DO",
        "class_name": "TestAgentDO",
      },
      {
        "name": "EMIT_DO",
        "class_name": "EmitTestDO",
      },
      {
        "name": "DISPATCH_DO",
        "class_name": "DispatchTestDO",
      },
      {
        "name": "STREAM_DO",
        "class_name": "StreamTestDO",
      },
      {
        "name": "SUBMIT_STREAM_DO",
        "class_name": "SubmitStreamTestDO",
      },
      {
        "name": "EXTENSION_DO",
        "class_name": "ExtensionTestDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "TestAgentDO",
        "EmitTestDO",
        "DispatchTestDO",
        "StreamTestDO",
        "SubmitStreamTestDO",
        "ExtensionTestDO",
      ],
    },
  ],
}

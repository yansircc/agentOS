{
  "compilerOptions": {
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/packages-runtime.tsbuildinfo",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers",
      "@cloudflare/vitest-pool-workers/types",
      "vitest/globals"
    ],
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "vitest.config.ts",
    "vitest.cloudflare.config.ts",
    "vitest.node.config.ts",
    "../../tooling/types/vite-plus-test-config/index.d.ts"
  ],
  "extends": "../../tsconfig.source-paths.json"
}

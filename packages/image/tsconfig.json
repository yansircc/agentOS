{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@agent-os/core/extensions": ["../core/src/extensions.ts"],
      "@agent-os/core/material-ref": ["../core/src/material-ref.ts"],
      "@agent-os/core/ref-resolver": ["../core/src/ref-resolver.ts"]
    },
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*", "test/**/*", "vitest.config.ts"]
}

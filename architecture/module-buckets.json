{
  "schemaVersion": 1,
  "policy": {
    "classification": "first matching rule wins",
    "ambientIsolation": "module labels and profile gates enforce ambient separation; packages are not security boundaries",
    "productBucket": "product is an ejection marker, not a final substrate bucket"
  },
  "productEjection": {
    "packagePathPrefixes": ["packages/"],
    "reason": "product modules are forbidden in substrate package roots; repo-local tooling may remain outside final substrate packages"
  },
  "buckets": [
    {
      "id": "axioms",
      "rank": 0,
      "description": "shared vocabulary, value brands, schemas, and substrate axioms"
    },
    {
      "id": "ledger",
      "rank": 1,
      "description": "durable ledger write, read, and storage mechanics"
    },
    {
      "id": "projection",
      "rank": 2,
      "description": "ledger-derived readers, folds, carriers, and wire projections"
    },
    {
      "id": "adapter",
      "rank": 3,
      "description": "target, provider, framework, transport, and implementation adapters"
    },
    {
      "id": "product",
      "rank": 4,
      "description": "consumer/product code that must be ejected before final substrate packaging",
      "ejection": true
    }
  ],
  "ambients": [
    {
      "id": "neutral",
      "allowedImports": ["neutral"]
    },
    {
      "id": "browser",
      "allowedImports": ["neutral", "browser"]
    },
    {
      "id": "node",
      "allowedImports": ["neutral", "node"]
    },
    {
      "id": "cloudflare-worker",
      "allowedImports": ["neutral", "cloudflare-worker"]
    },
    {
      "id": "product",
      "allowedImports": ["neutral", "browser", "node", "cloudflare-worker", "product"]
    }
  ],
  "bucketRules": [
    {
      "id": "product-docs-site",
      "match": "prefix",
      "value": "tooling/docs-site/",
      "bucket": "product"
    },
    {
      "id": "product-path-segment",
      "match": "contains",
      "value": "/product/",
      "bucket": "product"
    },
    {
      "id": "kernel-axioms",
      "match": "prefix",
      "value": "packages/core/",
      "bucket": "axioms"
    },
    {
      "id": "runtime-protocol-axioms",
      "match": "prefix",
      "value": "packages/core/src/runtime-protocol/",
      "bucket": "axioms"
    },
    {
      "id": "telemetry-protocol-axioms",
      "match": "prefix",
      "value": "packages/core/src/telemetry-protocol/",
      "bucket": "axioms"
    },
    {
      "id": "llm-protocol-axioms",
      "match": "prefix",
      "value": "packages/core/src/llm-protocol/",
      "bucket": "axioms"
    },
    {
      "id": "backend-protocol-axioms",
      "match": "prefix",
      "value": "packages/core/src/backend-protocol/",
      "bucket": "axioms"
    },
    {
      "id": "client-react-adapter",
      "match": "prefix",
      "value": "packages/client/src/react/",
      "bucket": "adapter"
    },
    {
      "id": "client-svelte-adapter",
      "match": "prefix",
      "value": "packages/client/src/svelte/",
      "bucket": "adapter"
    },
    {
      "id": "client-projection",
      "match": "prefix",
      "value": "packages/client/",
      "bucket": "projection"
    },
    {
      "id": "ops-api-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/cloudflare/ops-api/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-public-barrel-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/index.ts",
      "bucket": "adapter"
    },
    {
      "id": "runtime-folded-projection-files",
      "match": "regex",
      "value": "^packages/runtime/src/(ag-ui|attached-stream-protocol|sse-http)\\.ts$",
      "bucket": "projection"
    },
    {
      "id": "runtime-folded-carrier-projections",
      "match": "regex",
      "value": "^packages/runtime/src/(decision-gate|workspace-job-carrier|workspace-op-carrier)/",
      "bucket": "projection"
    },
    {
      "id": "runtime-local-provider-adapters",
      "match": "regex",
      "value": "^packages/runtime/src/(workspace-binding|workspace-op-local)\\.ts$",
      "bucket": "adapter"
    },
    {
      "id": "runtime-capability-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/capability/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-live-loop-adapter",
      "match": "regex",
      "value": "^packages/runtime/src/(attached-stream|driver|submit-agent|workspace-job)\\.ts$",
      "bucket": "adapter"
    },
    {
      "id": "runtime-submit-agent-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/submit-agent/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-projection-files",
      "match": "regex",
      "value": "^packages/runtime/src/(continuation|input-request|projection|run-projector|workspace-job-observability)\\.ts$",
      "bucket": "projection"
    },
    {
      "id": "runtime-cloudflare-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/cloudflare/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-in-memory-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/in-memory/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-node-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/node/",
      "bucket": "adapter"
    },
    {
      "id": "backend-ledger-file",
      "match": "contains",
      "value": "/ledger.ts",
      "bucket": "ledger"
    },
    {
      "id": "backend-ledger",
      "match": "regex",
      "value": "^packages/runtime/src/(?:cloudflare|in-memory|node)/(?:ledger|storage)/",
      "bucket": "ledger"
    },
    {
      "id": "ledger-path",
      "match": "contains",
      "value": "/ledger/",
      "bucket": "ledger"
    },
    {
      "id": "storage-path",
      "match": "contains",
      "value": "/storage/",
      "bucket": "ledger"
    },
    {
      "id": "commit-file",
      "match": "contains",
      "value": "/commit.ts",
      "bucket": "ledger"
    },
    {
      "id": "runtime-llm-effect-ai-adapter",
      "match": "prefix",
      "value": "packages/runtime/src/llm-effect-ai/",
      "bucket": "adapter"
    },
    {
      "id": "runtime-telemetry-otlp-projection",
      "match": "prefix",
      "value": "packages/runtime/src/telemetry-otlp/",
      "bucket": "projection"
    },
    {
      "id": "runtime-ledger",
      "match": "prefix",
      "value": "packages/runtime/",
      "bucket": "ledger"
    },
    {
      "id": "projection-name",
      "match": "contains",
      "value": "projection",
      "bucket": "projection"
    },
    {
      "id": "projector-name",
      "match": "contains",
      "value": "projector",
      "bucket": "projection"
    },
    {
      "id": "safe-events-name",
      "match": "contains",
      "value": "safe-events",
      "bucket": "projection"
    },
    {
      "id": "default-adapter",
      "match": "all",
      "bucket": "adapter"
    }
  ],
  "ambientRules": [
    {
      "id": "product-docs-site",
      "match": "prefix",
      "value": "tooling/docs-site/",
      "ambient": "product"
    },
    {
      "id": "product-path-segment",
      "match": "contains",
      "value": "/product/",
      "ambient": "product"
    },
    {
      "id": "runtime-node",
      "match": "prefix",
      "value": "packages/runtime/src/node/",
      "ambient": "node"
    },
    {
      "id": "cli",
      "match": "prefix",
      "value": "packages/cli/",
      "ambient": "node"
    },
    {
      "id": "distribution-tooling",
      "match": "prefix",
      "value": "tooling/distribution/",
      "ambient": "node"
    },
    {
      "id": "runtime-cloudflare",
      "match": "prefix",
      "value": "packages/runtime/src/cloudflare/",
      "ambient": "cloudflare-worker"
    },
    {
      "id": "client-react-browser",
      "match": "prefix",
      "value": "packages/client/src/react/",
      "ambient": "browser"
    },
    {
      "id": "client-svelte-browser",
      "match": "prefix",
      "value": "packages/client/src/svelte/",
      "ambient": "browser"
    },
    {
      "id": "client-neutral",
      "match": "prefix",
      "value": "packages/client/",
      "ambient": "neutral"
    },
    {
      "id": "default-neutral",
      "match": "all",
      "ambient": "neutral"
    }
  ],
  "externalAmbients": [
    {
      "id": "node-builtins",
      "match": "prefix",
      "value": "node:",
      "ambient": "node"
    },
    {
      "id": "pg",
      "match": "specifier-or-subpath",
      "value": "pg",
      "ambient": "node"
    },
    {
      "id": "cloudflare-workers-types",
      "match": "specifier",
      "value": "@cloudflare/workers-types",
      "ambient": "cloudflare-worker"
    },
    {
      "id": "cloudflare-builtins",
      "match": "prefix",
      "value": "cloudflare:",
      "ambient": "cloudflare-worker"
    },
    {
      "id": "react",
      "match": "specifier-or-subpath",
      "value": "react",
      "ambient": "browser"
    },
    {
      "id": "svelte",
      "match": "specifier-or-subpath",
      "value": "svelte",
      "ambient": "browser"
    }
  ],
  "reportMode": {
    "enforcement": "report until backlog is zero, then switch to enforce",
    "findingKinds": ["bucket-dag", "ambient-dag", "external-ambient", "product-ejection"]
  }
}

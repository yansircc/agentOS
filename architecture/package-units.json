{
  "schemaVersion": 1,
  "policy": {
    "packageBoundary": "split only when a package-wide obligation cannot be localized by subpath exports and optional peer dependencies",
    "namespaceSplit": "targetSourcePackageName is private build metadata; publicPackageName is the @yansirplus distribution projection; ownerId is not a package name",
    "effectPeer": "effect is a single required peer range invariant across package units that use Effect"
  },
  "packageUnits": [
    {
      "id": "core",
      "targetSourcePackageName": "@agent-os/core",
      "publicPackageName": "@yansirplus/core",
      "status": "target",
      "hardInstallEnvelope": {
        "dependencies": [],
        "installScripts": [],
        "nativeArtifacts": [],
        "packageWideMetadata": [],
        "requiredPeers": [
          {
            "name": "effect",
            "range": "^4.0.0-beta.84"
          }
        ]
      },
      "runtimeConditions": ["neutral"],
      "targetProfiles": ["neutral"],
      "publicSubpaths": [
        {
          "subpath": ".",
          "moduleBuckets": ["axioms"],
          "optionalPeers": []
        }
      ]
    },
    {
      "id": "runtime",
      "targetSourcePackageName": "@agent-os/runtime",
      "publicPackageName": "@yansirplus/runtime",
      "status": "target",
      "hardInstallEnvelope": {
        "dependencies": [],
        "installScripts": [],
        "nativeArtifacts": [],
        "packageWideMetadata": [],
        "requiredPeers": [
          {
            "name": "effect",
            "range": "^4.0.0-beta.84"
          }
        ]
      },
      "runtimeConditions": ["neutral", "cloudflare-worker", "node"],
      "targetProfiles": ["neutral", "cloudflare-worker", "node"],
      "publicSubpaths": [
        {
          "subpath": ".",
          "moduleBuckets": ["ledger", "projection"],
          "optionalPeers": []
        },
        {
          "subpath": "./cloudflare",
          "moduleBuckets": ["ledger", "adapter"],
          "optionalPeers": [
            "@agent-os/ag-ui",
            "@agent-os/sse-http",
            "@agent-os/workspace-env",
            "@agent-os/workspace-env-cloudflare",
            "@agent-os/workspace-op",
            "@agent-os/workspace-op-local",
            "@cloudflare/workers-types",
            "@effect/ai-anthropic",
            "@effect/sql-sqlite-do"
          ]
        },
        {
          "subpath": "./cloudflare/do-rpc",
          "moduleBuckets": ["adapter"],
          "optionalPeers": ["@cloudflare/workers-types"]
        },
        {
          "subpath": "./cloudflare/ops-api",
          "moduleBuckets": ["adapter"],
          "optionalPeers": ["@cloudflare/workers-types"]
        },
        {
          "subpath": "./in-memory",
          "moduleBuckets": ["ledger", "adapter"],
          "optionalPeers": []
        },
        {
          "subpath": "./node",
          "moduleBuckets": ["ledger", "adapter"],
          "optionalPeers": []
        },
        {
          "subpath": "./llm-effect-ai",
          "moduleBuckets": ["adapter"],
          "optionalPeers": ["@effect/ai-anthropic"]
        },
        {
          "subpath": "./telemetry-otlp",
          "moduleBuckets": ["projection"],
          "optionalPeers": []
        }
      ]
    },
    {
      "id": "client",
      "targetSourcePackageName": "@agent-os/client",
      "publicPackageName": "@yansirplus/client",
      "status": "target",
      "hardInstallEnvelope": {
        "dependencies": [],
        "installScripts": [],
        "nativeArtifacts": [],
        "packageWideMetadata": [],
        "requiredPeers": []
      },
      "runtimeConditions": ["browser"],
      "targetProfiles": ["browser"],
      "publicSubpaths": [
        {
          "subpath": ".",
          "moduleBuckets": ["projection"],
          "optionalPeers": []
        },
        {
          "subpath": "./react",
          "moduleBuckets": ["adapter"],
          "optionalPeers": ["react"]
        },
        {
          "subpath": "./svelte",
          "moduleBuckets": ["adapter"],
          "optionalPeers": ["svelte"]
        }
      ]
    },
    {
      "id": "cli",
      "targetSourcePackageName": "@agent-os/cli",
      "publicPackageName": "@yansirplus/cli",
      "status": "target",
      "hardInstallEnvelope": {
        "dependencies": [],
        "installScripts": [],
        "nativeArtifacts": [],
        "packageWideMetadata": [],
        "requiredPeers": [
          {
            "name": "effect",
            "range": "^4.0.0-beta.84"
          }
        ]
      },
      "runtimeConditions": ["node"],
      "targetProfiles": ["node"],
      "publicSubpaths": [
        {
          "subpath": ".",
          "moduleBuckets": ["adapter"],
          "optionalPeers": []
        }
      ]
    }
  ]
}

{
  "schemaVersion": 1,
  "proofClasses": {
    "structural": {
      "command": "pnpm run check:structural",
      "always": true
    },
    "typecheck": {
      "command": "pnpm run typecheck",
      "always": true
    },
    "test": {
      "command": "pnpm run test",
      "always": true
    },
    "docs": {
      "command": "pnpm run docs:check",
      "always": true
    },
    "runtime": {
      "command": "pnpm run check:runtime",
      "expensive": true
    },
    "distribution": {
      "command": "pnpm run check:distribution",
      "expensive": true
    },
    "effect-scan": {
      "command": "pnpm run agentos check effect-scan --evidence /tmp/agentos-effect-scan",
      "expensive": true
    }
  },
  "expensiveProofClasses": ["runtime", "distribution", "effect-scan"],
  "fullAffectedProofClasses": ["runtime", "distribution", "effect-scan"],
  "defaultPackageProof": {
    "fastProof": "test",
    "proofClasses": ["test"],
    "affectedProofClasses": []
  },
  "packageOverrides": [
    {
      "path": "packages/runtime",
      "fastProof": "test",
      "proofClasses": ["test", "runtime"],
      "affectedProofClasses": ["runtime"],
      "reason": "Runtime contains Cloudflare, in-memory, and Node profile subpaths; profile conformance includes Workers runtime and Postgres harness proof."
    }
  ],
  "changedPathProofRules": [
    {
      "patterns": ["packages/*/package.json", "packages/*/*/package.json"],
      "proofClasses": ["distribution"],
      "reason": "Package manifest changes affect distribution packaging."
    },
    {
      "patterns": ["docs/surface.json", "docs/api/**"],
      "proofClasses": ["distribution"],
      "reason": "Public API and surface ownership changes affect distribution checks."
    }
  ],
  "globalSurfaces": [
    {
      "patterns": [
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "tsconfig.source-paths.json",
        ".github/**",
        "docs/agent/gates.source.json",
        "docs/agent/boundary-rules.source.json",
        "packages/cli/src/main.mjs",
        "packages/cli/src/runner.mjs",
        "packages/cli/src/check/**",
        "packages/cli/src/generate/**",
        "tooling/distribution/**",
        "tooling/vitest-config/**"
      ],
      "reason": "Changed gate, dependency graph, generator, selector, ownership, distribution, or global config surface."
    }
  ],
  "extraEdges": [
    {
      "from": "tooling/docs-site",
      "to": "packages/cli",
      "reason": "Docs site consumes generated projections owned by the agentOS CLI."
    }
  ],
  "performance": {
    "fastCheckBudgetMs": 60000,
    "reason": "Fast check budget is a ratchet; increases require an explicit baseline update."
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-os.dev/schemas/agent/invariants.source.schema.json",
  "title": "agentOS invariant source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "invariants"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "invariants": {
      "type": "array",
      "items": { "$ref": "#/$defs/invariant" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9][a-z0-9-]*)+$"
    },
    "path": {
      "type": "string",
      "pattern": "^(docs|packages|scripts|tooling|skills)/.+$"
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "docs", "tests"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "type": "string", "minLength": 1 },
        "docs": { "$ref": "#/$defs/path" },
        "tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/path" }
        }
      }
    }
  }
}

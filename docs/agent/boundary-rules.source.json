      "positiveAcceptance": {
        "commands": ["node tooling/agentos-cli/src/check/check-agent-routes.mjs"]
      },
      "diagnostics": ["agent decision graph must derive from primitive and rule sources"],
      "paths": ["docs/agent/*.source.json", "docs/agent/boundary-rules.source.json"],
      "commandGroup": "check-docs"
    },
    {
      "id": "transaction-sync",

  "rules": [
    {
      "id": "repo-tooling-surface",
      "owner": "root package.json and tooling/agentos-cli",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-tooling",
      "diagnostics": [
        "root command surface must stay collapsed to the private CLI and approved distribution/runtime commands",
        "scripts/ must remain reserved for parallel-dev shell helpers",
        "tooling CLI must not import packages/* source"
      ],
      "paths": [
        "package.json",
        "scripts/**",
        "tooling/agentos-cli/src/**/*.mjs",
        "docs/agent/boundary-rules.source.json"
      ],
      "commandGroup": "all",
      "constraints": {
        "rootScripts": [
          "agentos",
          "build:internal-packages",
          "check",
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "docs:check",
          "docs:generate",
          "docs:project",
          "docs:project:watch",
          "docs:site:build",
          "docs:site:check",
          "docs:site:dev",
          "effect-manifests:check",
          "effect-manifests:generate",
          "install:consumer",
          "pack:internal",
          "publish:internal",
          "publish:local",
          "registry:local",
          "restore:consumer",
          "test",
          "test:internal-consumer",
          "typecheck"
        ],
        "allowedPrefixedRootScripts": [
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "test:internal-consumer"
        ],
        "scriptsDirectoryAllowPrefixes": ["scripts/parallel-dev/"],
        "scriptsDirectoryAllowedExtensions": [".sh"],
        "forbiddenPackageSpecPrefixes": ["@agent-os/"],
        "forbiddenLegacyScriptReferencePattern": "scripts/(generate|check|audit|project|public-api|lib|backend-neutral|agent-doc|effect|carrier|source|spike|ag-ui|workspace|tool|failure|doc-)",
        "legacyReferenceScanRoots": ["AGENTS.md", "README.md", "docs", "tooling/refactor"]
      },
      "acceptance": {
        "engine": "algorithmic",
        "checker": "repo-tooling-surface",
        "reason": "repo tooling surface spans package.json, scripts/, CLI imports, and docs references as one projection verdict"
      }
    },
    {
      "id": "public-api",
      "owner": "docs/surface.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "projection",
      "diagnostics": ["public package exports must match generated PUBLIC_API projections"],
      "paths": ["docs/surface.json", "packages/**/package.json"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "public-api",
        "reason": "projection freshness requires deriving expected artifact state from multiple source facts"
      }
    },
    {
      "id": "client-boundaries",
      "owner": "tooling/refactor/a78-a94/client-app-kit-boundary.md and docs/surface.json",
      "invariantId": "invariant.client.projection-sink-boundary",
      "kind": "repo-boundary",
      "diagnostics": [
        "client core must remain transport-neutral and framework-free",
        "client framework packages must expose hooks/stores only, not components or UI read-model DTOs",
        "ag-ui framework packages must retire once client framework bridges exist"
      ],
      "paths": [
        "tooling/refactor/a78-a94/client-app-kit-boundary.md",
        "docs/surface.json",
        "packages/client/**",
        "packages/composers/workspace-agent/**",
        "packages/wire-adapters/ag-ui*/**"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "client-boundaries",
        "reason": "client/app-kit boundary spans workspace packages, docs/surface.json, and source imports, so it remains an explicit source projection checker"
      }
    },
    {
      "id": "convergence-boundary",
      "owner": "CST 418 and tooling/refactor/a78-a94/client-app-kit-boundary.md",
      "invariantId": "invariant.client.projection-sink-boundary",
      "kind": "repo-boundary",
      "diagnostics": [
        "post-v3 downstream surfaces must stay outside substrate truth ownership",
        "client/app-kit packages must satisfy client-boundaries",
        "spikes must remain ignored local pressure tests"
      ],
      "paths": [
        "tooling/refactor/a78-a94/client-app-kit-boundary.md",
        "docs/surface.json",
        "packages/client/**",
        "packages/composers/workspace-agent/**",
        "spikes/**",
        "tooling/agentos-cli/src/check/algorithmic-checks.mjs",
        "tooling/agentos-cli/src/main.mjs"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "convergence-boundary",
        "reason": "post-v3 boundary freeze is the conjunction of client/app-kit boundary and spike hygiene until role-survival owns package deletion decisions"
      }
    },
    {
      "id": "convergence-roles",
      "owner": "CST 419 and tooling/refactor/a78-a94/role-survival.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "every package, export, script, doc surface, and public vocabulary must project to exactly one v3 role",
        "role none means delete; multiple roles mean split or merge",
        "role-survival.source.json is the only role survival source"
      ],
      "paths": [
        "tooling/refactor/a78-a94/role-survival.source.json",
        "docs/surface.json",
        "docs/agent/*.source.json",
        "docs/api/*.md",
        "docs/packages/*.md",
        "packages/**/package.json",
        "packages/**/PUBLIC_API.md",
        "tooling/**/package.json",
        "tooling/agentos-cli/src/check/algorithmic-checks.mjs"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "convergence-roles",
        "reason": "role survival is a positive projection from role-survival.source.json over the actual package/export/script/doc/vocabulary inventory"
      }
    },
    {
      "id": "substrate-import-dag",
      "owner": "docs/agent/boundary-rules.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "workspace package imports must remain acyclic",
        "foundational substrate packages must not import downstream runtime, adapter, provider, client, or tooling surfaces"
      ],
      "paths": [
        "docs/agent/boundary-rules.source.json",
        "packages/**/src/**/*.ts",
        "tooling/**/src/**/*.ts"
      ],
      "commandGroup": "all",
      "constraints": {
        "forbiddenEdges": [
          {
            "fromPackageNames": ["@agent-os/kernel"],
            "forbiddenTargetPackagePathPrefixes": ["packages", "tooling"]
          },
          {
            "fromPackageNames": [
              "@agent-os/attached-stream",
              "@agent-os/backend-protocol",
              "@agent-os/llm-protocol",
              "@agent-os/runtime-protocol",
              "@agent-os/telemetry-protocol"
            ],
            "forbiddenTargetPackagePathPrefixes": [
              "packages/runtime",
              "packages/backends",
              "packages/carriers",
              "packages/composers",
              "packages/execution-domains",
              "packages/providers",
              "packages/transports",
              "packages/wire-adapters",
              "packages/client",
              "tooling"
            ],
            "allowedTargetPackageNames": ["@agent-os/backend-protocol"]
          },
          {
            "fromPackageNames": ["@agent-os/runtime"],
            "forbiddenTargetPackagePathPrefixes": [
              "packages/backends",
              "packages/composers",
              "packages/execution-domains",
              "packages/providers",
              "packages/transports",
              "packages/wire-adapters",
              "packages/client",
              "tooling"
            ],
            "allowedTargetPackageNames": ["@agent-os/attached-stream", "@agent-os/backend-protocol"]
          }
        ]
      },
      "acceptance": {
        "engine": "algorithmic",
        "checker": "substrate-import-dag",
        "reason": "substrate import layering requires package source import graph traversal plus the source-owned forbidden edge constraints in this rule"
      }
    },
    {
      "id": "event-namespaces",
      "owner": "BoundaryContract declarations",
      "invariantId": "invariant.d10.namespace-integrity",
      "kind": "repo-boundary",
      "diagnostics": ["event kind prefixes must have exactly one owner"],
      "paths": ["packages/**/src/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "event-namespaces",
        "reason": "event namespace ownership requires AST collection across package source declarations and event writes"
      }
    },
    {
      "id": "docs-structure",
      "owner": "docs source facts and generated docs projections",
      "invariantId": "invariant.docs.agent-projection",
      "kind": "projection",
      "acceptance": {
        "engine": "generatedProjection",
        "command": "node tooling/agentos-cli/src/generate/generate-docs.mjs --check && node tooling/agentos-cli/src/generate/generate-agent-docs.mjs --check && bun tooling/agentos-cli/src/generate/generate-carrier-reference.mjs --check && node tooling/agentos-cli/src/generate/project-docs-site.mjs --check"
      },
      "diagnostics": [
        "generated docs structure must match declared source facts and generator ownership"
      ],
      "paths": [
        "docs/**",
        "tooling/docs-site/src/content/docs/**",
        "tooling/agentos-cli/src/generate/**/*.mjs"
      ],
      "commandGroup": "check-docs"
    },
    {
      "id": "agent-routes",
      "owner": "docs/agent/capability-rules.source.json",
      "invariantId": "invariant.docs.agent-projection",
      "kind": "projection",
      "diagnostics": ["agent decision graph must derive from primitive and rule sources"],
      "paths": ["docs/agent/*.source.json", "docs/agent/boundary-rules.source.json"],
      "commandGroup": "check-docs",
      "acceptance": {
        "engine": "generatedProjection",
        "command": "node tooling/agentos-cli/src/generate/generate-agent-docs.mjs --check"
      }
    },
    {
      "id": "transaction-sync",
      "owner": "backend protocol transaction contract",
      "invariantId": "invariant.ledger.single-commit-source",
      "kind": "repo-boundary",
      "diagnostics": ["transactionSync must remain sync-only substrate"],
      "paths": ["packages/backends/**/src/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "transaction-sync",
        "reason": "transactionSync ownership requires AST/source-shape analysis of rollback-only synchronous storage boundaries"
      }
    },
    {
      "id": "limit-registry",
      "owner": "kernel limit registry",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["limit declarations must use the registry instead of local strings"],
      "paths": ["packages/**/src/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "limit-registry",
        "reason": "cross-file source contract requires a projection checker until the assertion is represented by a smaller manifest engine"
      }
    },
    {
      "id": "workspace-job",
      "owner": "@agent-os/workspace-job",
      "invariantId": "invariant.workspace-job.verified-terminal",
      "kind": "carrier",
      "diagnostics": ["workspace-job terminal vocabulary remains carrier-owned"],
      "paths": ["packages/carriers/workspace-job", "packages/runtime/test/workspace-job.test.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "packageCommand",
        "commands": ["bun run --cwd packages/carriers/workspace-job test"]
      }
    },
    {
      "id": "observability",
      "owner": "@agent-os/runtime",
      "invariantId": "invariant.workspace-job.failure-observability-join",
      "kind": "projection",
      "diagnostics": ["workspace-job failure explanation must be a runtime join"],
      "paths": ["packages/runtime/src", "packages/runtime/test/workspace-job.test.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "packageCommand",
        "commands": ["bun run --cwd packages/runtime test -- test/workspace-job.test.ts"]
      }
    },
    {
      "id": "cloudflare-profile",
      "owner": "@agent-os/backend-cloudflare-do",
      "invariantId": "invariant.workspace-job.host-workspace-lifecycle",
      "kind": "profile",
      "diagnostics": ["Cloudflare profile composes host helpers without taking carrier truth"],
      "paths": ["packages/backends/cloudflare-do"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "packageCommand",
        "commands": [
          "bun run --cwd packages/backends/cloudflare-do test -- test/workspace-host-helpers.test.ts"
        ]
      }
    },
    {
      "id": "ag-ui-egress-allowlist",
      "owner": "@agent-os/ag-ui",
      "invariantId": "invariant.boundary.owner-owned-safe-projection",
      "kind": "wire-egress",
      "diagnostics": ["AG-UI egress exposes only owner-safe envelope and frame facts"],
      "paths": [
        "packages/wire-adapters/ag-ui/src/index.ts",
        "packages/wire-adapters/ag-ui/test/ag-ui.test.ts"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "packageCommand",
        "commands": ["bun run --cwd packages/wire-adapters/ag-ui test -- test/ag-ui.test.ts"]
      }
    },
    {
      "id": "boundaries",
      "owner": "BoundaryContract checklist",
      "invariantId": "invariant.d10.namespace-integrity",
      "kind": "repo-boundary",
      "diagnostics": ["live edge and boundary contract surfaces stay closed"],
      "paths": ["packages/kernel/src", "packages/**/src"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "boundaries",
        "reason": "BoundaryContract surface verification interprets cross-package boundary declarations"
      }
    },
    {
      "id": "backend-neutrality",
      "owner": "package.json agentos.backendNeutrality",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["production backend set must stay declared once"],
      "paths": ["package.json", "packages/backends"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "backend-neutrality",
        "reason": "cross-file source contract requires a projection checker until the assertion is represented by a smaller manifest engine"
      }
    },
    {
      "id": "source-aliases",
      "owner": "tooling/vitest-config/source-aliases.ts",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["source alias declarations must not fork package ownership"],
      "paths": ["tooling/vitest-config/source-aliases.ts", "tsconfig.source-paths.json"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "source-aliases",
        "reason": "source alias verification compares workspace package manifests and tsconfig graph shape"
      }
    },
    {
      "id": "spike-hygiene",
      "owner": "AGENTS.md Repo Surface",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["spikes must remain ignored local pressure tests"],
      "paths": ["spikes"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "spike-hygiene",
        "reason": "cross-file source contract requires a projection checker until the assertion is represented by a smaller manifest engine"
      }
    },
    {
      "id": "failure-diagnostics-envelope",
      "owner": "@agent-os/runtime-protocol",
      "invariantId": "invariant.boundary.owner-owned-safe-projection",
      "kind": "package-test",
      "diagnostics": [
        "failure diagnostics are projected from protocol categories, not SubmitResult"
      ],
      "paths": ["packages/runtime-protocol/test/failure-diagnostics.test.ts"],
      "commandGroup": "package-owned",
      "acceptance": {
        "engine": "packageCommand",
        "commands": [
          "bun run --cwd packages/runtime-protocol test -- test/failure-diagnostics.test.ts"
        ]
      }
    },
    {
      "id": "tool-witness-single-source",
      "owner": "@agent-os/kernel",
      "invariantId": "invariant.algebra.type-or-boot-proof",
      "kind": "package-test",
      "diagnostics": ["tool replay witness is derived from execution domain law"],
      "paths": [
        "packages/kernel/test/tools.test.ts",
        "packages/runtime-protocol/test/runtime-events.test.ts"
      ],
      "commandGroup": "package-owned",
      "acceptance": {
        "engine": "packageCommand",
        "commands": [
          "bun run --cwd packages/kernel test -- test/tools.test.ts",
          "bun run --cwd packages/runtime-protocol test -- test/runtime-events.test.ts"
        ]
      }

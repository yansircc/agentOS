  "rules": [
    {
      "id": "repo-tooling-surface",
      "owner": "root package.json and packages/cli",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-tooling",
      "diagnostics": [
        "root command surface must stay collapsed to the CLI package and approved distribution/runtime commands",
        "scripts/ must remain reserved for parallel-dev shell helpers",
        "CLI must not import packages/* source outside packages/cli"
      ],
      "paths": [
        "package.json",
        "scripts/**",
        "packages/cli/src/**/*.mjs",
        "docs/agent/boundary-rules.source.json"
      ],
      "commandGroup": "all",
      "constraints": {
        "rootScripts": [
          "agentos",
          "build:internal-packages",
          "check",
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "check:structural",
          "docs:check",
          "docs:generate",
          "docs:project",
          "docs:project:watch",
          "docs:site:build",
          "docs:site:check",
          "docs:site:dev",
          "effect-manifests:check",
          "effect-manifests:generate",
          "install:consumer",
          "pack:internal",
          "publish:internal",
          "publish:local",
          "registry:local",
          "restore:consumer",
          "test",
          "test:internal-consumer",
          "typecheck"
        ],
        "allowedPrefixedRootScripts": [
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "check:structural",
          "test:internal-consumer"
        ],
        "scriptsDirectoryAllowPrefixes": ["scripts/parallel-dev/"],
        "scriptsDirectoryAllowedExtensions": [".sh"],
        "forbiddenPackageSpecPrefixes": ["@agent-os/"],
        "forbiddenLegacyScriptReferencePattern": "scripts/(generate|check|audit|project|public-api|lib|backend-neutral|agent-doc|effect|carrier|source|spike|ag-ui|workspace|tool|failure|doc-)",
        "legacyReferenceScanRoots": ["AGENTS.md", "README.md", "docs", "tooling/refactor"]
      },
      "acceptance": {
        "engine": "algorithmic",
        "checker": "repo-tooling-surface",
        "reason": "repo tooling surface spans package.json, scripts/, CLI imports, and docs references as one projection verdict"
      }
    },
    {
      "id": "gate-tier-governance",
      "owner": "docs/agent/gates.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "gate tier ownership, runtime suffix routing, and affected graph fidelity derive from one gate manifest"
      ],
      "paths": [
        "docs/agent/gates.source.json",
        "package.json",
        "packages",
        "packages/cli/src/check"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "gate-tier-governance",
        "reason": "gate tier governance requires workspace package manifests, runtime suffix scan, proof ownership manifest, and affected graph fidelity checks"
      }
    },
    {
      "id": "public-api",
      "owner": "docs/surface.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "projection",
      "diagnostics": ["public package exports must match generated PUBLIC_API projections"],
      "paths": ["docs/surface.json", "packages/**/package.json"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "public-api",
        "reason": "projection freshness requires deriving expected artifact state from multiple source facts"
      }
    },
    {
      "id": "client-boundaries",
      "owner": "packages/cli/src/check/sources/client-workspace-host-boundary.md and docs/surface.json",
      "invariantId": "invariant.client.projection-sink-boundary",
      "kind": "repo-boundary",
      "diagnostics": [
        "client core must remain transport-neutral and framework-free",
        "client framework packages must expose hooks/stores only, not components or UI read-model DTOs",
        "ag-ui framework packages must retire once client framework bridges exist"
      ],
      "paths": [
        "packages/cli/src/check/sources/client-workspace-host-boundary.md",
        "docs/surface.json",
        "packages/client/**",
        "packages/composers/workspace-agent/**",
        "packages/wire-adapters/ag-ui*/**"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "client-boundaries",
        "reason": "client/workspace-host boundary spans workspace packages, docs/surface.json, and source imports, so it remains an explicit source projection checker"
      }
    },
    {
      "id": "convergence-boundary",
      "owner": "CST 418, CST 455, packages/cli/src/check/sources/client-workspace-host-boundary.md, and packages/composers/agent-authoring/src/index.ts",
      "invariantId": "invariant.client.projection-sink-boundary",
      "kind": "repo-boundary",
      "diagnostics": [
        "post-v3 downstream surfaces must stay outside substrate truth ownership",
        "client/workspace-host packages must satisfy client-boundaries",
        "closed target implementation wiring must be static imports and factory composition, not runtime selection from manifest/deployment JSON",
        "spikes must remain an ignored local namespace with zero tracked files"
      ],
      "paths": [
        "packages/cli/src/check/sources/client-workspace-host-boundary.md",
        "docs/surface.json",
        "packages/client/**",
        "packages/composers/workspace-agent/**",
        "packages/composers/agent-authoring/src/index.ts",
        "packages/composers/agent-authoring/test/agent-authoring.test.ts",
        ".gitignore",
        "packages/cli/src/check/algorithmic-checks.mjs",
        "packages/cli/src/main.mjs"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "convergence-boundary",
        "reason": "post-v3 boundary freeze is the conjunction of client/workspace-host boundary, generated static-target linking, and spike hygiene"
      }
    },
    {
      "id": "convergence-public-surface",
      "owner": "CST 421 and packages/cli/src/check/sources/public-surface-sweep.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "deprecated exports are compatibility shims and must not survive",
        "retired public framework packages must not remain in workspace or docs/surface",
        "retained projection vocabulary must be source-owned with explicit reason"
      ],
      "paths": [
        "packages/cli/src/check/sources/public-surface-sweep.source.json",
        "docs/surface.json",
        "docs/api/*.md",
        "packages/**/PUBLIC_API.md",
        "packages/**/package.json",
        "packages/cli/src/check/algorithmic-checks.mjs"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "convergence-public-surface",
        "reason": "public surface sweep composes public-api, module-bucket, distribution-unit, client-boundary, and explicit deprecated/retired surface rules"
      }
    },
    {
      "id": "convergence-import-dag",
      "owner": "architecture/module-buckets.json and docs/agent/boundary-rules.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "every workspace package import must remain acyclic",
        "module-buckets.json is the only bucket and ambient source for import DAG layering",
        "module imports must flow through the declared bucket DAG and ambient DAG without using package survival roles"
      ],
      "paths": [
        "architecture/module-buckets.json",
        "docs/agent/boundary-rules.source.json",
        "packages/**/src/**/*.ts",
        "tooling/**/src/**/*.ts"
      ],
      "commandGroup": "all",
      "constraints": {},
      "acceptance": {
        "engine": "algorithmic",
        "checker": "convergence-import-dag",
        "reason": "post-v3 import layering is package acyclicity plus module-bucket and ambient DAG enforcement"
      }
    },
    {
      "id": "substrate-import-dag",
      "owner": "docs/agent/boundary-rules.source.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": [
        "workspace package imports must remain acyclic",
        "foundational substrate packages must not import downstream runtime, adapter, provider, client, or tooling surfaces"
      ],
      "paths": [
        "docs/agent/boundary-rules.source.json",
        "packages/**/src/**/*.ts",
        "tooling/**/src/**/*.ts"
      ],
      "commandGroup": "all",
      "constraints": {
        "forbiddenEdges": [
          {
            "fromPackageNames": ["@agent-os/core"],
            "forbiddenTargetPackagePathPrefixes": ["packages", "tooling"]
          },
          {
            "fromPackageNames": [
              "@agent-os/attached-stream",
              "@agent-os/backend-protocol",
              "@agent-os/llm-protocol",
              "@agent-os/runtime-protocol",
              "@agent-os/telemetry-protocol"
            ],
            "forbiddenTargetPackagePathPrefixes": [
              "packages/runtime",
              "packages/runtime/src",
              "packages/carriers",
              "packages/composers",
              "packages/execution-domains",
              "packages/providers",
              "packages/transports",
              "packages/wire-adapters",
              "packages/client",
              "tooling"
            ],
            "allowedTargetPackageNames": ["@agent-os/backend-protocol"]
          },
          {
            "fromPackageNames": ["@agent-os/runtime"],
            "forbiddenTargetPackagePathPrefixes": [
              "packages/runtime/src",
              "packages/composers",
              "packages/execution-domains",
              "packages/providers",
              "packages/transports",
              "packages/wire-adapters",
              "packages/client",
              "tooling"
            ],
            "allowedTargetPackageNames": ["@agent-os/attached-stream", "@agent-os/backend-protocol"]
          }
        ]
      },
      "acceptance": {
        "engine": "algorithmic",
        "checker": "substrate-import-dag",
        "reason": "substrate import layering requires package source import graph traversal plus the source-owned forbidden edge constraints in this rule"
      }
    },
    {
      "id": "event-namespaces",
      "owner": "BoundaryContract declarations",
      "invariantId": "invariant.d10.namespace-integrity",
      "kind": "repo-boundary",
      "diagnostics": ["event kind prefixes must have exactly one owner"],
      "paths": ["packages/**/src/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "event-namespaces",
        "reason": "event namespace ownership requires AST collection across package source declarations and event writes"
      }
    },
    {
      "id": "docs-structure",
      "owner": "docs source facts and generated docs projections",
      "invariantId": "invariant.docs.agent-projection",
      "kind": "projection",
      "acceptance": {
        "engine": "proofClass",
        "proofClasses": ["docs"]
      },
      "diagnostics": [
        "generated docs structure must match declared source facts and generator ownership"
      ],
      "paths": [
        "docs/**",
        "tooling/docs-site/src/content/docs/**",
        "packages/cli/src/generate/**/*.mjs"
      ],
      "commandGroup": "check-docs"
    },
    {
      "id": "agent-routes",
      "owner": "docs/agent/capability-rules.source.json",
      "invariantId": "invariant.docs.agent-projection",
      "kind": "projection",
      "diagnostics": ["agent decision graph must derive from primitive and rule sources"],
      "paths": ["docs/agent/*.source.json", "docs/agent/boundary-rules.source.json"],
      "commandGroup": "check-docs",
      "acceptance": {
        "engine": "generatedProjection",
        "command": "node packages/cli/src/generate/generate-agent-docs.mjs --check"
      }
    },
    {
      "id": "transaction-sync",
      "owner": "backend protocol transaction contract",
      "invariantId": "invariant.ledger.single-commit-source",
      "kind": "repo-boundary",
      "diagnostics": ["transactionSync must remain sync-only substrate"],
      "paths": ["packages/runtime/src/{cloudflare,in-memory,node}/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "transaction-sync",
        "reason": "transactionSync ownership requires AST/source-shape analysis of rollback-only synchronous storage boundaries"
      }
    },
    {
      "id": "limit-registry",
      "owner": "kernel limit registry",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["limit declarations must use the registry instead of local strings"],
      "paths": ["packages/**/src/**/*.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "limit-registry",
        "reason": "cross-file source contract requires a projection checker until the assertion is represented by a smaller manifest engine"
      }
    },
    {
      "id": "workspace-job",
      "owner": "@agent-os/workspace-job",
      "invariantId": "invariant.workspace-job.verified-terminal",
      "kind": "carrier",
      "diagnostics": ["workspace-job terminal vocabulary remains carrier-owned"],
      "paths": ["packages/carriers/workspace-job", "packages/runtime/test/workspace-job.test.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "proofClass",
        "proofClasses": ["test"]
      }
    },
    {
      "id": "observability",
      "owner": "@agent-os/runtime",
      "invariantId": "invariant.workspace-job.failure-observability-join",
      "kind": "projection",
      "diagnostics": ["workspace-job failure explanation must be a runtime join"],
      "paths": ["packages/runtime/src", "packages/runtime/test/workspace-job.test.ts"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "proofClass",
        "proofClasses": ["test"]
      }
    },
    {
      "id": "cloudflare-profile",
      "owner": "@agent-os/runtime/cloudflare",
      "invariantId": "invariant.workspace-job.host-workspace-lifecycle",
      "kind": "profile",
      "diagnostics": ["Cloudflare profile composes host helpers without taking carrier truth"],
      "paths": ["packages/runtime/src/cloudflare"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "proofClass",
        "proofClasses": ["test"]
      }
    },
    {
      "id": "ag-ui-egress-allowlist",
      "owner": "@agent-os/ag-ui",
      "invariantId": "invariant.boundary.owner-owned-safe-projection",
      "kind": "wire-egress",
      "diagnostics": ["AG-UI egress exposes only owner-safe envelope and frame facts"],
      "paths": [
        "packages/wire-adapters/ag-ui/src/index.ts",
        "packages/wire-adapters/ag-ui/test/ag-ui.test.ts"
      ],
      "commandGroup": "all",
      "acceptance": {
        "engine": "proofClass",
        "proofClasses": ["test"]
      }
    },
    {
      "id": "boundaries",
      "owner": "BoundaryContract checklist",
      "invariantId": "invariant.d10.namespace-integrity",
      "kind": "repo-boundary",
      "diagnostics": ["live edge and boundary contract surfaces stay closed"],
      "paths": ["packages/core/src", "packages/**/src"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "boundaries",
        "reason": "BoundaryContract surface verification interprets cross-package boundary declarations"
      }
    },
    {
      "id": "backend-neutrality",
      "owner": "package.json agentos.backendNeutrality",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["production backend set must stay declared once"],
      "paths": ["package.json", "packages/runtime/src"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "backend-neutrality",
        "reason": "cross-file source contract requires a projection checker until the assertion is represented by a smaller manifest engine"
      }
    },
    {
      "id": "source-aliases",
      "owner": "tooling/vitest-config/source-aliases.ts",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["source alias declarations must not fork package ownership"],
      "paths": ["tooling/vitest-config/source-aliases.ts", "tsconfig.source-paths.json"],
      "commandGroup": "all",
      "acceptance": {
        "engine": "algorithmic",
        "checker": "source-aliases",
        "reason": "source alias verification compares workspace package manifests and tsconfig graph shape"
      }
    },
    {
      "id": "spike-hygiene",
      "owner": "AGENTS.md Repo Surface",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-boundary",
      "diagnostics": ["spikes must remain an ignored local namespace with zero tracked files"],
      "paths": [".gitignore"],
      "commandGroup": "all",

  "rules": [
    {
      "id": "repo-tooling-surface",
      "owner": "root package.json and tooling/agentos-cli",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "repo-tooling",
      "positiveAcceptance": {
        "commands": ["node tooling/agentos-cli/src/check/check-repo-tooling-surface.mjs"]
      },
      "diagnostics": [
        "root command surface must stay collapsed to the private CLI and approved distribution/runtime commands",
        "scripts/ must remain reserved for parallel-dev shell helpers",
        "tooling CLI must not import packages/* source"
      ],
      "paths": [
        "package.json",
        "scripts/**",
        "tooling/agentos-cli/src/**/*.mjs",
        "docs/agent/boundary-rules.source.json"
      ],
      "commandGroup": "all",
      "constraints": {
        "rootScripts": [
          "agentos",
          "build:internal-packages",
          "check",
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "docs:check",
          "docs:generate",
          "docs:project",
          "docs:project:watch",
          "docs:site:build",
          "docs:site:check",
          "docs:site:dev",
          "effect-manifests:check",
          "effect-manifests:generate",
          "install:consumer",
          "pack:internal",
          "publish:internal",
          "publish:local",
          "registry:local",
          "restore:consumer",
          "test",
          "test:internal-consumer",
          "typecheck"
        ],
        "allowedPrefixedRootScripts": [
          "check:distribution",
          "check:full",
          "check:release",
          "check:runtime",
          "test:internal-consumer"
        ],
        "scriptsDirectoryAllowPrefixes": ["scripts/parallel-dev/"],
        "scriptsDirectoryAllowedExtensions": [".sh"],
        "forbiddenPackageSpecPrefixes": ["@agent-os/"],
        "forbiddenLegacyScriptReferencePattern": "scripts/(generate|check|audit|project|public-api|lib|backend-neutral|agent-doc|effect|carrier|source|spike|ag-ui|workspace|tool|failure|doc-)",
        "legacyReferenceScanRoots": ["AGENTS.md", "README.md", "docs", "tooling/refactor"]
      }
    },
    {
      "id": "public-api",
      "owner": "docs/surface.json",
      "invariantId": "invariant.algebra.single-code-source",
      "kind": "projection",
      "positiveAcceptance": {
        "commands": ["node tooling/agentos-cli/src/check/check-public-api.mjs"]
      },
      "diagnostics": ["public package exports must match generated PUBLIC_API projections"],
      "paths": ["docs/surface.json", "packages/**/package.json"],
      "commandGroup": "all"
    },
    {
      "id": "event-namespaces",
      "owner": "BoundaryContract declarations",
      "invariantId": "invariant.d10.namespace-integrity",
      "kind": "repo-boundary",
      "positiveAcceptance": {
        "commands": ["node tooling/agentos-cli/src/check/check-event-namespaces.mjs"]
      },
      "diagnostics": ["event kind prefixes must have exactly one owner"],
      "paths": ["packages/**/src/**/*.ts"],
      "commandGroup": "all"
    },
    {
      "id": "agent-routes",
      "owner": "docs/agent/capability-rules.source.json",
      "invariantId": "invariant.docs.agent-projection",
